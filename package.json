{
  "name": "mitchellake-signals",
  "version": "1.0.0",
  "description": "MitchelLake Signal Intelligence Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "init-db": "node scripts/init_db.js",
    "init-qdrant": "node scripts/init_qdrant.js",
    "harvest": "node scripts/harvest_rss.js",
    "embed": "node scripts/embed_documents.js",
    "signals": "node scripts/compute_signals.js",
    "scores": "node scripts/compute_scores.js",
    "match": "node scripts/match_searches.js",
    "enrich": "node scripts/enrich_content.js",
    "pipeline": "npm run harvest && npm run embed && npm run signals && npm run scores"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
