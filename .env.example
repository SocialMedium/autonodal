# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Qdrant (Qdrant Cloud - https://cloud.qdrant.io)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-api-key

# OpenAI
OPENAI_API_KEY=sk-your-key

# Server
PORT=3000
NODE_ENV=development

# Auth — Google OAuth only (mitchellake.com domain restricted)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# Xero OAuth 2.0 (https://developer.xero.com/app/manage)
XERO_CLIENT_ID=your-xero-app-client-id
XERO_CLIENT_SECRET=your-xero-app-client-secret
XERO_REDIRECT_URI=https://your-domain.com/api/xero/callback
